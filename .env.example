# Environment variables for ACPMS

# Database
# Replace the host port with: docker compose port postgres 5432
DATABASE_URL=postgres://acpms_user:acpms_password@127.0.0.1:5432/acpms

# Worktrees (directory for agent-cloned source code)
# Suggestion: ${HOME}/Projects
# WORKTREES_PATH=${HOME}/Projects

# Server
RUST_LOG=debug
RUST_BACKTRACE=1
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
APP_DOMAIN=localhost
API_PUBLIC_URL=http://localhost:3000

# JWT
JWT_SECRET=your-secret-key-change-in-production

# Encryption (Phase 3 - Security Hardening)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your-base64-encoded-32-byte-encryption-key

# GitLab (optional)
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=

# Cloudflare (optional)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Agent Runtime (CLI Provider)
#
# The backend can execute agent attempts via one of these local CLIs:
# - Claude Code CLI (Anthropic)
# - Codex CLI (OpenAI)
# - Gemini CLI (Google)
#
# Select the provider in the UI: Settings -> Agent CLI Provider.
#
# Optional: override session/config directories
# CLAUDE_SESSION_DIR=~/.claude
# CODEX_CONFIG_DIR=~/.codex
# GEMINI_CONFIG_DIR=~/.gemini
#
# Optional: provide API keys via env instead of storing them in DB
# OPENAI_API_KEY=
# CODEX_API_KEY=
# GEMINI_API_KEY=

# S3 / MinIO (default: MinIO via Docker)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=admin
S3_SECRET_KEY=adminpassword123
S3_BUCKET_NAME=acpms-media
# Presigned upload/avatar URLs: must be reachable from the user's browser (e.g. over internet).
# Use your public app URL + /s3 (e.g. https://app.auxbase.space/s3). Backend appends / so path is .../s3/acpms-media/...
# If you get 413 Content Too Large on uploads: increase body size in front of the app (e.g. nginx client_max_body_size; Cloudflare → consider Direct Upload or higher plan).
S3_PUBLIC_ENDPOINT=https://your-domain.com/s3
# Set to 1 for local MinIO (CORS config often fails; browser uploads may need proxy CORS)
# S3_SKIP_CORS_CONFIG=1
